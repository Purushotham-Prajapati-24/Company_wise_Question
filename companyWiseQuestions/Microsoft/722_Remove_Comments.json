  "explanation": "Iterate character by character, tracking if inside a block comment or line comment.",
  "answer": "def removeComments(source):\n    res, in_block, cur = [], False, \"\"\n    for line in source:\n        i = 0\n        while i < len(line):\n            if not in_block:\n                if line[i:i+2] == '/*': in_block = True; i += 1\n                elif line[i:i+2] == '//': break\n                else: cur += line[i]\n            elif line[i:i+2] == '*/': in_block = False; i += 1\n            i += 1\n        if not in_block and cur: res.append(cur); cur = \"\"\n    return res",
