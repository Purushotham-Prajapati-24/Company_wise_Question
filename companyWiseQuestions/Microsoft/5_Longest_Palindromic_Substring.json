    "answer": "def longestPadding(s):\n    res = \"\"\n    for i in range(len(s)):\n        for l, r in [(i,i), (i,i+1)]:\n            while l>=0 and r<len(s) and s[l]==s[r]:\n                if r-l+1 > len(res): res=s[l:r+1]\n                l-=1; r+=1\n    return res",
