  "answer": "def getHint(secret, guess):\n    bulls = sum(s == g for s, g in zip(secret, guess))\n    import collections\n    s_counts, g_counts = collections.Counter(secret), collections.Counter(guess)\n    cows = sum(min(s_counts[c], g_counts[c]) for c in s_counts) - bulls\n    return f\"{bulls}A{cows}B\"",
