{
  "question_text": "<h3>Sort Array By Parity</h3><p>Given an integer array <code>nums</code>, move all the even integers at the beginning of the array followed by all the odd integers.</p>",
  "difficulty": "EASY",
  "marks": 10,
  "input_format": "Int array nums.",
  "output_format": "Int array sorted.",
  "constraints": [
    "1 <= nums.length <= 5000",
    "0 <= nums[i] <= 5000"
  ],
  "explanation": "Use two pointers, $i$ at start and $j$ at end. Swap `nums[i]` and `nums[j]` if `nums[i]` is odd and `nums[j]` is even. Increment $i$ if `nums[i]` is even, and decrement $j$ if `nums[j]` is odd.",
  "answer": "def sortArrayByParity(nums):\n    l, r = 0, len(nums) - 1\n    while l < r:\n        if nums[l] % 2 > nums[r] % 2: nums[l], nums[r] = nums[r], nums[l]\n        if nums[l] % 2 == 0: l += 1\n        if nums[r] % 2 == 1: r -= 1\n    return nums",
  "boilerplate": {
    "python": "import sys\nimport json\n\ndef solve(*args):\n    # Implement 905 Sort Array By Parity here\n    pass\n\nif __name__ == '__main__':\n    data = sys.stdin.read().strip().split('\\n')\n    if not data or data == ['']: sys.exit(0)\n    args = [json.loads(line) for line in data]\n    print(json.dumps(solve(*args)))",
    "cpp": "#include <iostream>\n#include <vector>\n#include <string>\n#include <algorithm>\nusing namespace std;\nint main() { string line; while (getline(cin, line)) {} return 0; }",
    "java": "import java.util.*;\nimport java.io.*;\npublic class Main {\n    public static void main(String[] args) throws IOException {\n        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));\n        String line; while ((line = br.readLine()) != null) {}\n    }\n}",
