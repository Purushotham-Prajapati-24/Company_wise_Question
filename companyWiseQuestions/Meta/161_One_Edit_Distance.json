  "answer": "def isOneEditDistance(s, t):\n    if s == t: return False\n    if abs(len(s)-len(t)) > 1: return False\n    for i in range(min(len(s), len(t))):\n        if s[i] != t[i]:\n            if len(s) == len(t): return s[i+1:] == t[i+1:]\n            if len(s) < len(t): return s[i:] == t[i+1:]\n            return s[i+1:] == t[i:]\n    return True",
