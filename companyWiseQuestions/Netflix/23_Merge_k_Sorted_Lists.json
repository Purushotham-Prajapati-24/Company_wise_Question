{
  "question_text": "<h3>Merge k Sorted Lists</h3><p>Merge $k$ sorted linked lists and return it as one sorted list.</p>",
  "difficulty": "HARD",
  "marks": 10,
  "input_format": "lists of heads.",
  "output_format": "Merged head.",
  "constraints": [
    "k <= 10^4",
    "total nodes <= 10^4"
  ],
  "explanation": "Use a min-heap to keep track of the smallest current node among all $k$ lists. At each step, extract the min, add it to result, and push its next node back to the heap.",
  "answer": "def mergeKLists(lists):\n    h = []\n    for i, node in enumerate(lists):\n        if node: heapq.heappush(h, (node.val, i, node))\n    dummy = tail = ListNode()\n    while h:\n        val, i, node = heapq.heappop(h)\n        tail.next = node; tail = tail.next\n        if node.next: heapq.heappush(h, (node.next.val, i, node.next))\n    return dummy.next",
  "boilerplate": {
    "python": "import sys\nimport json\n\ndef solve(*args):\n    # Implement 23 Merge k Sorted Lists here\n    pass\n\nif __name__ == '__main__':\n    data = sys.stdin.read().strip().split('\\n')\n    if not data or data == ['']: sys.exit(0)\n    args = [json.loads(line) for line in data]\n    print(json.dumps(solve(*args)))",
    "cpp": "#include <iostream>\n#include <vector>\n#include <string>\n#include <algorithm>\nusing namespace std;\nint main() { string line; while (getline(cin, line)) {} return 0; }",
