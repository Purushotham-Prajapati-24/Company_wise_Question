{
  "question_text": "<h3>Basic Calculator II</h3><p>Evaluate non-negative integer expressions (+, -, *, /).</p>",
  "difficulty": "MEDIUM",
  "marks": 10,
  "input_format": "s.",
  "output_format": "int.",
  "constraints": [
    "len <= 3*10^5"
